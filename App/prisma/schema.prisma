generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./app.db"
}

model Client {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  fullName     String
  gender       String
  dob          DateTime
  phoneNumber  String?
  village      String?
  profileImage Bytes?

  deletedAt    DateTime?
  lastModified DateTime  @default(now())
  revision     Int       @default(0)

  visits       Visit[]
  encounters   ClinicEncounter[]

  @@index([fullName])
}

model Visit {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())

  visitDate                    DateTime @default(now())
  doctorName                   String
  presentingComplaint          String @default("")
  historyOfPresentingComplaint String @default("")
  observationAndExamination    String @default("")
  impression                   String @default("")
  plan                         String @default("")
  notes                        String?

  clientId     String
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  forms        VisitForm[]
  attachments  VisitAttachment[]
}

model Template {
  id           String   @id @default(cuid())
  name         String
  structure    String

  forms        VisitForm[]
}

model VisitForm {
  id           String   @id @default(cuid())

  visitId      String
  visit        Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)

  templateId   String
  template     Template @relation(fields: [templateId], references: [id])

  answers      String
}

model VisitAttachment {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())

  visitId      String
  visit        Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)

  fileName     String
  fileType     String
  fileData     Bytes
  fileSize     Int
}

// ─── Clinic Flow ────────────────────────────────────────────────────────────

model ClinicSession {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clinicName   String
  location     String
  date         DateTime
  startTime    DateTime
  endTime      DateTime
  dailyTarget  Int      @default(50)
  isActive     Boolean  @default(false)
  endedAt      DateTime?

  encounters   ClinicEncounter[]

  @@index([date])
  @@index([isActive])
}

// Status values (enforced by Zod, stored as String in SQLite):
// registered | in_triage | triage_completed | in_examination |
// examination_completed | in_diagnosis | waiting_medication |
// completed_medication_given | completed_no_meds | referred
model ClinicEncounter {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  status       String   @default("registered")

  // Triage
  bloodPressure      String?
  heartRate          String?
  temperature        String?
  spO2               String?
  weight             String?
  mainComplaint      String?
  medicalHistory     String?
  currentMedications String?
  allergies          String?
  redFlags           String?
  drugHistory        String?
  familyHistory      String?
  socialHistory      String?

  // Examination
  examinationPerformed String?
  examinationResults   String?

  // Diagnosis & Prescribing
  diagnosis          String?
  clinicalNotes      String?
  treatmentAdvice    String?
  prescription       String?
  followUpAdvice     String?
  referral           Boolean  @default(false)
  medicationNeeded   Boolean  @default(false)
  prescriberNotes    String?

  // Medication
  medicationGivenAt  DateTime?

  clientId     String
  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)

  sessionId    String
  session      ClinicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([clientId, sessionId])
  @@index([status])
  @@index([sessionId])
}
