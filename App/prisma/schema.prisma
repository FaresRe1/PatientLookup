generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./app.db"
}

model Client {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  
  fullName     String
  gender       String
  dob          DateTime
  email        String?   @unique
  phoneNumber  String?
  address      String?
  profileImage Bytes?
  drugHistory  String    @default("")
  familyHistory String   @default("")
  socialHistory String   @default("")
  
  deletedAt    DateTime?
  lastModified DateTime  @default(now())
  revision     Int       @default(0)

  visits       Visit[]  
  
  @@index([fullName])
}

model Visit {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  
  visitDate    DateTime @default(now())
  doctorName   String
  notes        String?  
  
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  forms        VisitForm[]
  attachments  VisitAttachment[]
}

model Template {
  id           String   @id @default(cuid())
  name         String  
  structure    String   // Stores the questions as a JSON String? Maybe?
  
  forms        VisitForm[]
}

model VisitForm {
  id           String   @id @default(cuid())
  
  visitId      String
  visit        Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)
  
  templateId   String
  template     Template @relation(fields: [templateId], references: [id])
  
  answers      String   // Stores the answers as a JSON String? Maybe?
}

model VisitAttachment {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  
  visitId      String
  visit        Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)
  
  fileName     String   // Original file name (e.g., "photo.jpg", "scan.pdf")
  fileType     String   // MIME type (e.g., "image/jpeg", "application/pdf")
  fileData     Bytes    // Actual file content stored as BLOB
  fileSize     Int      // Size in bytes
}